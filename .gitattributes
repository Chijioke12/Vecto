# Set default behavior to automatically handle line endings
* text=auto eol=lf

# Force bash/sh scripts, gradlew wrapper to use LF line endings
gradlew text eol=lf
*.sh text eol=lf

# Force batch scripts for Windows to use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Prevent git from corrupting binary files on checkout/commit
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.keystore binary
*.bin binary
